{
	"name": "compilecat",
	"version": "0.0.0",
	"description": "compiler plugin that helps you write high performance javascript.",
	"author": "Isaac Mason <isaac@isaacmason.com>",
	"license": "MIT",
	"type": "module",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.ts"
			},
			"import": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"import": "./dist/vite.js"
		},
		"./webpack": {
			"types": "./dist/webpack.d.ts",
			"import": "./dist/webpack.js"
		},
		"./rollup": {
			"types": "./dist/rollup.d.ts",
			"import": "./dist/rollup.js"
		},
		"./esbuild": {
			"types": "./dist/esbuild.d.ts",
			"import": "./dist/esbuild.js"
		},
		"./rolldown": {
			"types": "./dist/rolldown.d.ts",
			"import": "./dist/rolldown.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "rm -rf ./dist && rollup --config rollup.config.ts",
		"format": "biome format --write src/. tst/.",
		"lint": "biome lint --write src/. tst/.",
		"test": "vitest"
	},
	"devDependencies": {
		"@babel/generator": "^7.28.5",
		"@babel/parser": "^7.28.5",
		"@babel/traverse": "^7.28.5",
		"@babel/types": "^7.28.5",
		"@biomejs/biome": "^2.2.0",
		"@rollup/plugin-node-resolve": "^16.0.1",
		"@rollup/plugin-typescript": "^12.1.4",
		"@types/babel__generator": "^7.27.0",
		"@types/babel__traverse": "^7.28.0",
		"@types/node": "latest",
		"chalk": "^5.6.2",
		"esbuild": "^0.25.10",
		"rollup": "^4.46.2",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-esbuild": "^6.2.1",
		"rollup-plugin-filesize": "^10.0.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	},
	"peerDependencies": {
		"@babel/parser": "^7.26.3",
		"@babel/traverse": "^7.26.4",
		"@babel/types": "^7.26.3"
	},
	"packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a",
	"dependencies": {
		"es-module-lexer": "^2.0.0",
		"glob": "^13.0.0",
		"unplugin": "^2.3.11"
	}
}