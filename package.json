{
	"name": "compilecat",
	"version": "0.0.3",
	"description": "compiler plugin that helps you write high performance javascript.",
	"author": "Isaac Mason <isaac@isaacmason.com>",
	"license": "MIT",
	"type": "module",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.ts"
			},
			"import": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"import": "./dist/vite.js"
		},
		"./rollup": {
			"types": "./dist/rollup.d.ts",
			"import": "./dist/rollup.js"
		},
		"./rolldown": {
			"types": "./dist/rolldown.d.ts",
			"import": "./dist/rolldown.js"
		},
		"./wasm": {
			"types": "./dist/wasm.d.ts",
			"import": "./dist/wasm.js"
		}
	},
	"files": [
		"dist",
		"!dist/core/*.node",
		"README.md",
		"LICENSE",
		"NOTICE"
	],
	"scripts": {
		"build": "pnpm build:rust && pnpm build:ts && pnpm build:loader",
		"clean": "node scripts/clean.mjs",
		"release:publish": "node scripts/publish.mjs",
		"release": "pnpm clean && pnpm build:native && pnpm build:wasm && pnpm test && pnpm build:all && pnpm build:ts && pnpm build:loader && node -e \"console.log('\\n✓ ready to publish — run: pnpm release:publish')\"",
		"build:ts": "rm -rf ./dist && rollup --config rollup.config.ts",
		"build:loader": "mkdir -p dist/core && cp rust/crates/compilecat_napi/index.js rust/crates/compilecat_napi/index.d.ts dist/core/ && node -e \"require('fs').writeFileSync('dist/core/package.json', JSON.stringify({ type: 'commonjs' }))\" && (cp rust/crates/compilecat_napi/*.node dist/core/ 2>/dev/null || true)",
		"build:all": "node scripts/build-all.mjs",
		"build:rust": "pnpm build:native && pnpm build:wasm",
		"build:native": "pnpm -C rust/crates/compilecat_napi run build",
		"build:native:debug": "pnpm -C rust/crates/compilecat_napi run build:debug",
		"build:wasm": "wasm-pack build rust/crates/compilecat_wasm --target web --release && node scripts/patch-wasm-pkg.mjs",
		"build:wasm:debug": "wasm-pack build rust/crates/compilecat_wasm --target web --dev",
		"format": "biome format --write src/. tst/.",
		"lint": "biome lint --write src/. tst/.",
		"test": "pnpm test:rust && pnpm test:js",
		"test:rust": "cargo test --manifest-path rust/Cargo.toml -p compilecat_core",
		"test:js": "vitest run",
		"fuzz": "FUZZ=1 vitest run tst/fuzz.test.ts",
		"version:all": "node scripts/bump-version.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@rollup/plugin-node-resolve": "^16.0.1",
		"@rollup/plugin-typescript": "^12.1.4",
		"@types/node": "latest",
		"chalk": "^5.6.2",
		"esbuild": "^0.25.10",
		"rolldown": "^1.1.1",
		"rollup": "^4.46.2",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-esbuild": "^6.2.1",
		"rollup-plugin-filesize": "^10.0.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	},
	"peerDependencies": {
		"rollup": "^4.0.0"
	},
	"optionalDependencies": {
		"@compilecat/core-darwin-arm64": "0.0.3",
		"@compilecat/core-darwin-x64": "0.0.3",
		"@compilecat/core-linux-x64-gnu": "0.0.3",
		"@compilecat/core-linux-arm64-gnu": "0.0.3",
		"@compilecat/core-win32-x64-msvc": "0.0.3",
		"@compilecat/core-wasm32-wasi": "0.0.3",
		"@compilecat/wasm": "0.0.3"
	},
	"packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a"
}
